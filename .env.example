# GEMINI_API_KEY: Required for secure server-side Google Gemini API calls.
GEMINI_API_KEY="your_gemini_api_key_here"

# GEMINI_MODEL: The model to use for AI calls
GEMINI_MODEL="gemini-2.5-flash"

# CONTACT_EMAIL: Email address that receives contact form submissions.
CONTACT_EMAIL="your-email@example.com"

# Optional public email shown in the UI. Leave empty to keep it private and use only the contact form.
VITE_PUBLIC_CONTACT_EMAIL=""
